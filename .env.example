# InsightLens environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# Flask session signing key. Generate a random hex string, for example:
#   python -c "import secrets; print(secrets.token_hex(32))"
# On Render this is generated automatically (see render.yaml).
SESSION_SECRET=replace_with_random_64_char_hex

# PostgreSQL connection string (Neon). Include sslmode=require for Neon.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# OpenAI is the live LLM provider. Required.
OPENAI_API_KEY=sk-replace-with-your-openai-key

# Admin cost dashboard login. You choose these values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# Optional. Monthly OpenAI budget cap in USD. Defaults to 20.0 if unset.
MONTHLY_API_BUDGET=20.0

# Do NOT set HUGGINGFACE_API_KEY.
# Setting it activates a dormant, broken Hugging Face code path. Leaving it
# unset routes all analysis through OpenAI, which is the working path.
